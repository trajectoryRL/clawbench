{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "sandbox-token-12345"
    },
    "tailscale": {
      "mode": "off"
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },
  "models": {
    "providers": {
      "chutes": {
        "baseUrl": "${CLAWBENCH_LLM_BASE_URL}",
        "api": "openai-completions",
        "apiKey": "${CLAWBENCH_LLM_API_KEY}",
        "models": [
          {
            "id": "zai-org/GLM-5-TEE",
            "name": "GLM-5-TEE (Chutes)",
            "reasoning": true,
            "maxTokens": 32768,
            "compat": {
              "thinkingFormat": "zai"
            },
            "cost": {
              "input": 1.00,
              "output": 3.20,
              "cacheRead": 1.00,
              "cacheWrite": 1.00
            }
          }
        ]
      },
      "zhipu": {
        "baseUrl": "${CLAWBENCH_LLM_BASE_URL}",
        "api": "openai-completions",
        "apiKey": "${CLAWBENCH_LLM_API_KEY}",
        "models": [
          {
            "id": "glm-5",
            "name": "GLM-5",
            "reasoning": true,
            "maxTokens": 32768,
            "compat": {
              "thinkingFormat": "zai"
            },
            "cost": {
              "input": 1.00,
              "output": 3.20,
              "cacheRead": 1.00,
              "cacheWrite": 1.00
            }
          }
        ]
      },
      "openrouter": {
        "baseUrl": "${CLAWBENCH_LLM_BASE_URL}",
        "api": "openai-completions",
        "apiKey": "${CLAWBENCH_LLM_API_KEY}",
        "models": [
          {
            "id": "z-ai/glm-5",
            "name": "GLM-5 (OpenRouter)",
            "reasoning": true,
            "maxTokens": 32768,
            "compat": {
              "thinkingFormat": "zai"
            },
            "cost": {
              "input": 1.00,
              "output": 3.20,
              "cacheRead": 1.00,
              "cacheWrite": 1.00
            }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/workspace",
      "skipBootstrap": true,
      "model": {
        "primary": "${CLAWBENCH_DEFAULT_MODEL}"
      }
    }
  },
  "plugins": {
    "slots": {
      "memory": "none"
    },
    "entries": {
      "clawbench-tools": {
        "enabled": true,
        "config": {
          "mockServerUrl": "${MOCK_TOOLS_URL}",
          "scenario": "default"
        }
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "enabled": false
      },
      "fetch": {
        "enabled": false
      }
    },
    "deny": [
      "process",
      "browser",
      "canvas",
      "nodes",
      "cron",
      "gateway",
      "apply_patch"
    ],
    "allow": [
      "email_list",
      "email_read",
      "email_send",
      "email_draft",
      "calendar_list",
      "calendar_search",
      "calendar_create",
      "tasks_list",
      "task_get",
      "task_create",
      "task_update",
      "slack_channels",
      "slack_read",
      "slack_send",
      "slack_member",
      "memory_search",
      "memory_read",
      "session_status"
    ]
  },
  "channels": {}
}
